{
  "datasets": [
    {
      "name": "2fc3c11b",
      "displayName": "Active Users by Region",
      "queryLines": [
        "SELECT\n",
        "  d.full_date AS order_date,\n",
        "  c.region,\n",
        "  COUNT(DISTINCT f.cust_key) AS active_users\n",
        "FROM\n",
        "  workspace.gold.fact_orders f\n",
        "    JOIN workspace.gold.dim_date d\n",
        "      ON f.date_key = d.date_key\n",
        "    JOIN workspace.gold.dim_customer c\n",
        "      ON f.cust_key = c.cust_key\n",
        "GROUP BY\n",
        "  d.full_date,\n",
        "  c.region\n",
        "ORDER BY\n",
        "  d.full_date,\n",
        "  c.region"
      ]
    },
    {
      "name": "sweet_category",
      "displayName": "Sweet Category Metrics",
      "queryLines": [
        "SELECT\n",
        "  d.year,\n",
        "  d.month_name,\n",
        "  p.top_category,\n",
        "  COUNT(DISTINCT f.order_id) AS order_count,\n",
        "  SUM(f.quantity) AS total_quantity,\n",
        "  ROUND(SUM(f.revenue_usd), 2) AS total_revenue_usd\n",
        "FROM\n",
        "  workspace.gold.fact_orders f\n",
        "    JOIN workspace.gold.dim_date d\n",
        "      ON f.date_key = d.date_key\n",
        "    JOIN workspace.gold.dim_product p\n",
        "      ON f.prod_key = p.prod_key\n",
        "WHERE\n",
        "  LOWER(p.top_category) = 'sweet'\n",
        "GROUP BY\n",
        "  d.year,\n",
        "  d.month_name,\n",
        "  d.month,\n",
        "  p.top_category\n",
        "ORDER BY\n",
        "  d.year,\n",
        "  d.month"
      ]
    },
    {
      "name": "fba3a792",
      "displayName": "Top Products by Region",
      "queryLines": [
        "WITH ranked AS (\n",
        "  SELECT\n",
        "    c.region,\n",
        "    p.prod_name,\n",
        "    p.top_category,\n",
        "    ROUND(SUM(f.revenue_usd), 2) AS total_revenue_usd,\n",
        "    RANK() OVER (PARTITION BY c.region ORDER BY SUM(f.revenue_usd) DESC) AS revenue_rank\n",
        "  FROM\n",
        "    workspace.gold.fact_orders f\n",
        "      JOIN workspace.gold.dim_customer c\n",
        "        ON f.cust_key = c.cust_key\n",
        "      JOIN workspace.gold.dim_product p\n",
        "        ON f.prod_key = p.prod_key\n",
        "  GROUP BY\n",
        "    c.region,\n",
        "    p.prod_name,\n",
        "    p.top_category\n",
        ")\n",
        "SELECT\n",
        "  region,\n",
        "  revenue_rank,\n",
        "  prod_name,\n",
        "  top_category,\n",
        "  total_revenue_usd\n",
        "FROM\n",
        "  ranked\n",
        "WHERE\n",
        "  revenue_rank <= 3\n",
        "ORDER BY\n",
        "  region,\n",
        "  revenue_rank"
      ]
    },
    {
      "name": "4384e9a5",
      "displayName": "CLV",
      "queryLines": [
        "SELECT\n",
        "  c.cust_key,\n",
        "  c.region,\n",
        "  c.customer_type,\n",
        "  CASE\n",
        "    WHEN c.is_active THEN 'active'\n",
        "    ELSE 'inactive'\n",
        "  END AS customer_status,\n",
        "  COUNT(DISTINCT f.order_id) AS total_orders,\n",
        "  SUM(f.quantity) AS total_units,\n",
        "  ROUND(SUM(f.revenue_usd), 2) AS lifetime_revenue_usd,\n",
        "  ROUND(AVG(f.revenue_usd), 2) AS avg_order_line_value_usd,\n",
        "  ROUND(DATEDIFF(CURRENT_DATE(), MIN(d.full_date)) / 30.0, 1) AS tenure_months\n",
        "FROM\n",
        "  workspace.gold.dim_customer c\n",
        "    LEFT JOIN workspace.gold.fact_orders f\n",
        "      ON c.cust_key = f.cust_key\n",
        "    LEFT JOIN workspace.gold.dim_date d\n",
        "      ON f.date_key = d.date_key\n",
        "GROUP BY\n",
        "  c.cust_key,\n",
        "  c.region,\n",
        "  c.customer_type,\n",
        "  c.is_active\n",
        "ORDER BY\n",
        "  lifetime_revenue_usd DESC"
      ]
    },
    {
      "name": "8f1d2012",
      "displayName": "Data Quality Audit",
      "queryLines": [
        "SELECT\n",
        "  'multi_line_order' AS flag_type,\n",
        "  order_id,\n",
        "  COUNT(*) AS line_count,\n",
        "  COLLECT_SET(prod_key) AS prod_keys,\n",
        "  ROUND(SUM(revenue_usd), 2) AS total_revenue_usd,\n",
        "  NULL AS error_reason\n",
        "FROM\n",
        "  workspace.gold.fact_orders\n",
        "GROUP BY\n",
        "  order_id\n",
        "HAVING\n",
        "  COUNT(*) > 1\n",
        "UNION ALL\n",
        "SELECT\n",
        "  _error_code AS flag_type,\n",
        "  order_id,\n",
        "  1 AS line_count,\n",
        "  NULL AS prod_keys,\n",
        "  NULL AS total_revenue_usd,\n",
        "  _error_message AS error_reason\n",
        "FROM\n",
        "  workspace.error_tables.err_orders\n",
        "ORDER BY\n",
        "  flag_type,\n",
        "  order_id"
      ]
    }
  ],
